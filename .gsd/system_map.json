{
  "pages": [
    {
      "page_name": "Login",
      "route": "/",
      "file_path": "public/index.html",
      "access_control": {
        "roles": [
          "any"
        ],
        "auth_required": false,
        "conditions": [
          "Redirects to dashboard if loggedInUser exists in localStorage"
        ]
      },
      "navigation": {
        "entry_points": [
          "index.html"
        ],
        "redirects": [
          "dashboard.html (on success)"
        ]
      },
      "features": [
        {
          "feature_name": "Authentication",
          "feature_type": "form",
          "description": "Secure login using username and password.",
          "ui_elements": {
            "type": "form",
            "details": {
              "fields": [
                "username",
                "password"
              ]
            }
          },
          "components_files": [
            "public/src/js/index.js"
          ],
          "permissions": [
            "public"
          ],
          "state_management": {
            "local_state": [
              "username",
              "password",
              "errorMsg"
            ],
            "global_state": [
              "localStorage.loggedInUser"
            ]
          },
          "interactions": [
            "form_submit"
          ],
          "data_flow": {
            "source": "User Input",
            "api_calls": [
              "/api/login"
            ],
            "transformations": [
              "bcrypt.compare (backend)"
            ],
            "derived_data": [
              "user_type",
              "offices"
            ]
          },
          "api": [
            {
              "endpoint": "/api/login",
              "method": "POST",
              "called_from": "index.js:login()",
              "params": [],
              "request_body": {
                "username": "string",
                "password": "password"
              },
              "response_schema": {
                "status": 200,
                "data": {
                  "user": {
                    "fullname": "string",
                    "user_type": "string",
                    "offices": "array"
                  }
                }
              },
              "error_cases": [
                "User not found",
                "Incorrect password"
              ]
            }
          ],
          "backend_mapping": {
            "controller": "app.js",
            "service_functions": [
              "apiCalls.loginUser"
            ],
            "logic_summary": "Validates credentials against 'users' collection using bcrypt.",
            "middleware": [
              "bodyParser.json"
            ]
          },
          "firestore": {
            "collections": [
              "users",
              "user_data",
              "office_assignment"
            ],
            "documents": [
              "user entry matching username"
            ],
            "queries": [
              "where('username', '==', username)"
            ],
            "relationships": [
              "users joined with user_data by idno",
              "users joined with office_assignment by idno"
            ]
          }
        }
      ]
    },
    {
      "page_name": "Dashboard",
      "route": "/dashboard.html",
      "file_path": "public/dashboard.html",
      "access_control": {
        "roles": [
          "user",
          "superadmin"
        ],
        "auth_required": true,
        "conditions": [
          "Requires loggedInUser in localStorage"
        ]
      },
      "navigation": {
        "entry_points": [
          "index.html",
          "sidebar"
        ],
        "redirects": [
          "index.html (if unauthorized)"
        ]
      },
      "features": [
        {
          "feature_name": "Per-Office Analytics",
          "feature_type": "dashboard",
          "description": "Dynamic analytics for each assigned office, including aggregation for PHO and PTO satellite offices.",
          "ui_elements": {
            "type": "dynamic_grid",
            "details": {
              "charts": [
                "Overall Feedback Rating",
                "Breakdown of Rating Data",
                "Overall Collection Rate",
                "Breakdown of Collection vs Logbook"
              ]
            }
          },
          "charts": [
            {
              "id": "rate",
              "name": "Overall Feedback Rating",
              "type": "bar",
              "aggregation": "Aggregated for PTO/PHO satellite offices"
            },
            {
              "id": "breakdown",
              "name": "Breakdown of Rating Data",
              "type": "line",
              "aggregation": "Aggregated for PTO/PHO satellite offices"
            },
            {
              "id": "collect",
              "name": "Overall Collection Rate",
              "type": "line",
              "aggregation": "Aggregated for PTO/PHO satellite offices"
            },
            {
              "id": "collectBreak",
              "name": "Breakdown of Collection vs Logbook",
              "type": "bar/line",
              "aggregation": "Aggregated for PTO/PHO satellite offices"
            }
          ]
        },
        {
          "feature_name": "Detailed Breakdown of Collection",
          "feature_type": "table",
          "description": "Detailed tabular data for collection and visitors. For PHO and PTO, it includes individual rows for each satellite office representing the actual table data.",
          "ui_elements": {
            "type": "data_table",
            "details": {
              "id": "tableCollect",
              "structure": "Rows per office/satellite, columns per month"
            }
          },
          "data_flow": {
            "transformations": [
              "Individual data extraction for satellite offices in PTO/PHO"
            ]
          }
        },
        {
          "feature_name": "Citizen's Charter Awareness",
          "feature_type": "table",
          "description": "Metrics on client awareness, visibility, and helpfulness of the Citizen's Charter. PTO/PHO sections include detailed breakdown of satellite offices using the exact legacy template.",
          "ui_elements": {
            "type": "data_table",
            "details": {
              "id": "tableCCQ",
              "columns": [
                "OFFICE",
                "AWARE",
                "VISIBLE",
                "HELPFUL",
                "CLIENTS"
              ]
            }
          },
          "data_flow": {
            "transformations": [
              "Extracting CC awareness metrics per satellite/office"
            ]
          }
        }
      ]
    },
    {
      "page_name": "Analytics Report",
      "route": "/report.html",
      "file_path": "public/report.html",
      "access_control": {
        "roles": [
          "superadmin"
        ],
        "auth_required": true,
        "conditions": []
      },
      "features": [
        {
          "feature_name": "Consolidation Report",
          "feature_type": "table",
          "description": "Detailed multi-point satisfaction metrics including CC awareness.",
          "ui_elements": {
            "type": "tabbed_view",
            "details": {
              "tabs": [
                "Data",
                "Summary",
                "Graphs"
              ]
            }
          },
          "components_files": [
            "public/src/js/report.js"
          ],
          "data_flow": {
            "api_calls": [
              "/api/getReport",
              "/api/generate-pdf"
            ]
          },
          "charts": {
            "chart_type": "line_chart",
            "library": "Chart.js",
            "data_fields": [
              "General Rating",
              "Monthly Trends"
            ]
          },
          "api": [
            {
              "endpoint": "/api/generate-pdf",
              "method": "POST",
              "called_from": "report.js:generateReport listener",
              "request_body": "Full reportData object"
            }
          ]
        }
      ]
    }
  ]
}
